{
  "name": "folk-mart-k6-performance-testing",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal k6 performance test suite for Folk Mart",
  "scripts": {
    "test:smoke": "k6 run k6-tests/src/scenarios/smoke.test.js",
    "test:load": "k6 run k6-tests/src/scenarios/load.test.js",
    "test:stress": "k6 run k6-tests/src/scenarios/stress.test.js",
    "test:spike": "k6 run k6-tests/src/scenarios/spike.test.js",
    "test:soak": "k6 run k6-tests/src/scenarios/soak.test.js",
    "test:cart-checkout": "k6 run k6-tests/src/scenarios/cart-checkout.test.js",
    "test:race": "k6 run k6-tests/src/scenarios/race-condition.test.js",
    "cloud:login": "k6 cloud login",
    "cloud:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/smoke.test.js -LocalExecution",
    "cloud:load": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/load.test.js -LocalExecution",
    "cloud:stress": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/stress.test.js -LocalExecution",
    "cloud:spike": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/spike.test.js -LocalExecution",
    "cloud:soak": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/soak.test.js -LocalExecution",
    "cloud:cart-checkout": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/cart-checkout.test.js -LocalExecution",
    "cloud:race": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-run.ps1 k6-tests/src/scenarios/race-condition.test.js -LocalExecution --env RACE_VUS=20 --env RACE_SPIKE_PRE_ALLOCATED_VUS=15 --env RACE_SPIKE_MAX_VUS=60",
    "cloud:quick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-suite.ps1 -Mode quick -LocalExecution",
    "cloud:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-suite.ps1 -Mode full -LocalExecution",
    "cloud:quick:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/k6-cloud-suite.ps1 -Mode quick -DryRun"
  }
}

